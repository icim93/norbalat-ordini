PORT=3000
JWT_SECRET=cambia-questo-segreto-in-produzione-2026
NODE_ENV=production

# Lookup automatico cliente da Partita IVA
# Usa un endpoint API che accetta la P.IVA, ad esempio con placeholder {piva}
# Esempio: https://api.tuoprovider.it/v1/imprese/{piva}
PIVA_LOOKUP_URL=
PIVA_LOOKUP_TOKEN=
PIVA_LOOKUP_AUTH_HEADER=Authorization
PIVA_LOOKUP_TOKEN_PREFIX=Bearer 
# Header extra in JSON, es: {"X-Api-Key":"abc123","X-Client":"norbalat"}
PIVA_LOOKUP_EXTRA_HEADERS=

# Notifiche email onboarding
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_SECURE=false
SMTP_FROM=
SMTP_FROM_NAME=Norbalat Ordini
NOTIFY_EMAIL_TO=
NOTIFY_TIMEZONE=Europe/Rome
